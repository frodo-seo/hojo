# ─────────────────────────────────────────────
# 소비일기 (sobi-ilgi) 환경변수 샘플
# 사용법: 이 파일을 복사해서 .env.local 로 만들고 값 채우기
#   cp .env.example .env.local
# ─────────────────────────────────────────────

# ── Anthropic Claude API ──
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Vision/Text 공용. 최신 모델 권장
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Chandra OCR (Datalab hosted) ──
# https://www.datalab.to 에서 API 키 발급
# POST /api/v1/ocr (multipart, X-API-Key 헤더)
DATALAB_API_KEY=xxxxxxxxxxxxxxxxxxxx
DATALAB_API_URL=https://www.datalab.to/api/v1

# ── Supabase ──
# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# 서버(Edge Function)에서만 사용 — 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ── 앱인토스 (Apps in Toss) ──
# 토스 개발자 콘솔에서 발급
APPS_IN_TOSS_APP_ID=
APPS_IN_TOSS_CLIENT_ID=
APPS_IN_TOSS_CLIENT_SECRET=

# ── 앱 기본 설정 ──
VITE_APP_NAME=소비일기
VITE_APP_ENV=development
# local / preview / production
